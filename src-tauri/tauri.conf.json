{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oryn",
  "version": "0.1.2",
  "identifier": "com.joaomdsferro.oryn",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "oryn",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "maximized": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#080e1a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
